#include <stdio.h>
#include <sys/ipc.h>
#include <sys/msg.h>
#include <string.h>

struct msg
{
    long type;
    char text[100];
}m;

int main()
{
    int msgid;

    msgid = msgget(1234,0666|IPC_CREAT);

    m.type = 1;

    printf("Enter message: ");
    scanf(" %[^\n]",m.text);

    msgsnd(msgid,&m,sizeof(m.text),0);

    printf("Message sent: %s\n",m.text);

    msgrcv(msgid,&m,sizeof(m.text),1,0);

    printf("Message received: %s\n",m.text);

    return 0;
}