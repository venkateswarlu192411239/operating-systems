#include <stdio.h>

int main(){
    int n, time=0;
    printf("Enter number of processes: ");
    scanf("%d",&n);

    int pid[n], at[n], bt[n], rt[n], priority[n], wt[n], tat[n];
    for(int i=0;i<n;i++){
        pid[i]=i+1;
        printf("P%d Arrival, Burst & Priority: ", i+1);
        scanf("%d%d%d",&at[i],&bt[i],&priority[i]);
        rt[i]=bt[i];
    }

    int completed=0;
    while(completed < n){
        int idx=-1;
        int high = -1;
        for(int i=0;i<n;i++){
            if(at[i]<=time && rt[i]>0){
                if(priority[i]>high){
                    high=priority[i];
                    idx=i;
                }
            }
        }
        if(idx == -1){
            time++;
            continue;
        }
        rt[idx]--;
        time++;

        if(rt[idx]==0){
            completed++;
            wt[idx]=time - at[idx] - bt[idx];
            tat[idx]=time - at[idx];
        }
    }

    printf("\nPID AT BT PRI WT TAT\n");
    for(int i=0;i<n;i++)
        printf("%d   %d   %d   %d   %d   %d\n",
               pid[i], at[i], bt[i], priority[i], wt[i], tat[i]);
    return 0;
}