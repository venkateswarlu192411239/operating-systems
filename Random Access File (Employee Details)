#include <stdio.h>

struct emp
{
    int id;
    char name[20];
    float salary;
}e;

int main()
{
    FILE *fp;
    int n,i;

    fp=fopen("emp.dat","w");

    printf("Enter number of employees: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        printf("\nEnter id name salary: ");
        scanf("%d %s %f",&e.id,e.name,&e.salary);

        fwrite(&e,sizeof(e),1,fp);
    }

    fclose(fp);

    fp=fopen("emp.dat","r");

    printf("\nEmployee Details\n");

    while(fread(&e,sizeof(e),1,fp))
        printf("%d %s %.2f\n",e.id,e.name,e.salary);

    fclose(fp);

    return 0;
}