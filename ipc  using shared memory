#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <string.h>

int main()
{
    int shmid;
    char *str;

    shmid = shmget(1122,1024,0666|IPC_CREAT);
    str = (char*) shmat(shmid,NULL,0);

    printf("Enter message: ");
    scanf(" %[^\n]",str);

    printf("Data written in memory: %s\n",str);

    shmdt(str);
    return 0;
}