#include <stdio.h>

int main(){
    int n;
    printf("Enter number of processes: ");
    scanf("%d",&n);

    int pid[n], at[n], bt[n], wt[n], tat[n], done[n];
    for(int i=0;i<n;i++){
        pid[i]=i+1;
        printf("P%d Arrival & Burst Time: ",i+1);
        scanf("%d%d",&at[i],&bt[i]);
        done[i]=0;
    }

    int time=0, completed=0;
    while(completed < n){
        int idx=-1, minb=100000;
        for(int i=0;i<n;i++){
            if(at[i]<=time && !done[i] && bt[i]<minb){
                minb=bt[i];
                idx=i;
            }
        }
        if(idx==-1){
            time++;
            continue;
        }
        wt[idx] = time - at[idx];
        time += bt[idx];
        tat[idx] = time - at[idx];
        done[idx] = 1;
        completed++;
    }

    printf("\nPID AT BT WT TAT\n");
    for(int i=0;i<n;i++)
        printf("%d   %d   %d   %d   %d\n",
               pid[i], at[i], bt[i], wt[i], tat[i]);
    return 0;
}